# Telegram API credentials (получить на https://my.telegram.org)
TELEGRAM_API_ID=твоё_число_здесь
TELEGRAM_API_HASH=твой_хэш_здесь

# Группа для извлечения постов (без @)
TELEGRAM_CHAT_USERNAME=inbox_tools

# Имя session-файла (без расширения, появится после авторизации)
TELEGRAM_SESSION_NAME=vibeos_capture

# SOCKS5 proxy (Tor) для обхода блокировки Telegram.
# Если пусто — proxy не используется (прямое соединение).
# Для Tor: TELEGRAM_PROXY_HOST=127.0.0.1, TELEGRAM_PROXY_PORT=9050
TELEGRAM_PROXY_HOST=127.0.0.1
TELEGRAM_PROXY_PORT=9050